{
  "name": "unpkg-esm",
  "description": "The ESM package import service for UNPKG",
  "private": true,
  "type": "module",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "unpkg-worker": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/bun": "^1.2.8",
    "@types/node": "^22.10.2",
    "unpkg-files": "workspace:*",
    "wrangler": "^4.3.0"
  },
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "dev": "wrangler dev --env dev --port 3002",
    "test": "bun --preload=./test/setup.ts test",
    "deploy": "../../scripts/with-local-env.sh wrangler deploy",
    "deploy:staging": "../../scripts/with-local-env.sh wrangler deploy --env staging"
  }
}
