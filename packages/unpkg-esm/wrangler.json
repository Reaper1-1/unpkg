{
  "compatibility_date": "2024-12-05",
  "main": "./src/worker.ts",

  "name": "unpkg-esm",
  "observability": { "enabled": true, "head_sampling_rate": 0.001 },
  "routes": [{ "pattern": "esm.unpkg.com", "custom_domain": true }],
  "vars": {
    "FILES_ORIGIN": "https://fly.unpkg.com",
    "MODE": "production",
    "ORIGIN": "https://esm.unpkg.com"
  },

  "env": {
    "dev": {
      "name": "unpkg-esm-dev",
      "routes": [],
      "vars": {
        "FILES_ORIGIN": "http://localhost:4000",
        "MODE": "development",
        "ORIGIN": "http://localhost:3002"
      }
    },

    "staging": {
      "name": "unpkg-esm-staging",
      "observability": { "enabled": true },
      "workers_dev": true,
      "routes": [{ "pattern": "esm.unpkg.dev", "custom_domain": true }],
      "vars": {
        "FILES_ORIGIN": "https://fly.unpkg.dev",
        "MODE": "staging",
        "ORIGIN": "https://esm.unpkg.dev"
      }
    }
  }
}
